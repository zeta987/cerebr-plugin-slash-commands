{
  "schemaVersion": 2,
  "id": "template.shell.reasoning-retry",
  "version": "0.1.0",
  "kind": "declarative",
  "scope": "shell",
  "displayName": "Reasoning Retry Policy Template",
  "description": "Retry when the model emits reasoning content without a final answer.",
  "defaultEnabled": true,
  "permissions": [
    "chat:retry"
  ],
  "activationEvents": ["hook:onResponseError"],
  "compatibility": {
    "versionRange": ">=2.4.86 <3.0.0"
  },
  "contributions": {
    "requestPolicies": [
      {
        "applyTo": {
          "modelIncludes": [
            "gemini"
          ]
        },
        "retry": {
          "onErrorCodes": [
            "CEREBR_REASONING_ONLY_RESPONSE",
            "CEREBR_MISFILED_THINK_SILENTLY"
          ],
          "maxAttempts": 6,
          "reason": "template:reasoning-retry"
        }
      }
    ]
  }
}
