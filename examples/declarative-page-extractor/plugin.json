{
  "schemaVersion": 2,
  "id": "template.page.article-focus",
  "version": "0.1.0",
  "kind": "declarative",
  "scope": "page",
  "displayName": "Article Focus Extractor Template",
  "description": "Prefer article-like selectors and strip common layout chrome before Cerebr extracts page text.",
  "defaultEnabled": true,
  "requiresExtension": true,
  "permissions": [
    "page:extractors"
  ],
  "activationEvents": ["page.ready"],
  "compatibility": {
    "versionRange": ">=2.4.86 <3.0.0"
  },
  "contributions": {
    "pageExtractors": [
      {
        "matches": [
          "*://*/*"
        ],
        "includeSelectors": [
          "article",
          "main",
          "[role=\"main\"]",
          ".article",
          ".post",
          ".entry-content",
          ".markdown-body"
        ],
        "excludeSelectors": [
          "nav",
          "header",
          "footer",
          "aside",
          ".sidebar",
          ".ads",
          ".advertisement",
          ".toc"
        ],
        "strategy": "replace",
        "priority": 10,
        "maxTextLength": 30000,
        "collapseWhitespace": true
      }
    ]
  }
}
