{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cerebr.dev/schemas/plugin.schema.json",
  "title": "Cerebr Plugin Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "kind",
    "scope",
    "displayName",
    "description"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [1, 2]
    },
    "id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "version": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "kind": {
      "type": "string",
      "enum": ["builtin", "declarative", "script"]
    },
    "scope": {
      "type": "string",
      "enum": ["page", "shell", "prompt", "background"]
    },
    "displayName": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "nameKey": {
      "type": "string"
    },
    "description": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "descriptionKey": {
      "type": "string"
    },
    "defaultEnabled": {
      "type": "boolean"
    },
    "publisher": {
      "type": "string"
    },
    "homepage": {
      "type": "string"
    },
    "permissions": {
      "$ref": "#/$defs/stringArray"
    },
    "requiresExtension": {
      "type": "boolean"
    },
    "activationEvents": {
      "$ref": "#/$defs/stringArray"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "script": {
      "$ref": "#/$defs/scriptBlock"
    },
    "declarative": {
      "$ref": "#/$defs/legacyDeclarative"
    },
    "contributions": {
      "$ref": "#/$defs/contributions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "background"
          }
        },
        "required": ["scope"]
      },
      "then": {
        "required": ["requiresExtension"],
        "properties": {
          "requiresExtension": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "script"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "required": ["script"]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "declarative"
          }
        },
        "required": ["kind"]
      },
      "then": {
        "anyOf": [
          {
            "required": ["declarative"]
          },
          {
            "required": ["contributions"]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "declarative": {
            "type": "object",
            "properties": {
              "type": {
                "const": "prompt_fragment"
              }
            },
            "required": ["type"]
          }
        },
        "required": ["declarative"]
      },
      "then": {
        "properties": {
          "scope": {
            "enum": ["prompt", "shell"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "declarative": {
            "type": "object",
            "properties": {
              "type": {
                "const": "request_policy"
              }
            },
            "required": ["type"]
          }
        },
        "required": ["declarative"]
      },
      "then": {
        "properties": {
          "scope": {
            "const": "shell"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "declarative": {
            "type": "object",
            "properties": {
              "type": {
                "const": "page_extractor"
              }
            },
            "required": ["type"]
          }
        },
        "required": ["declarative"]
      },
      "then": {
        "properties": {
          "scope": {
            "const": "page"
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "versionRange": {
          "type": "string"
        }
      }
    },
    "scriptBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry"],
      "properties": {
        "entry": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "module": {
          "type": "string"
        },
        "exportName": {
          "type": "string"
        }
      }
    },
    "promptFragment": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "anyOf": [
            {
              "required": ["content"]
            },
            {
              "required": ["contentKey"]
            }
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "contentKey": {
              "type": "string"
            },
            "placement": {
              "type": "string",
              "enum": ["system.prepend", "system.append"]
            },
            "priority": {
              "type": "number"
            }
          }
        }
      ]
    },
    "promptFragmentList": {
      "oneOf": [
        {
          "$ref": "#/$defs/promptFragment"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promptFragment"
          }
        }
      ]
    },
    "requestPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "applyTo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "modes": {
              "$ref": "#/$defs/stringArray"
            },
            "modelIncludes": {
              "$ref": "#/$defs/stringArray"
            },
            "urlIncludes": {
              "$ref": "#/$defs/stringArray"
            }
          }
        },
        "promptFragments": {
          "$ref": "#/$defs/promptFragmentList"
        },
        "requestPatch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "body": {
              "type": "object"
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onErrorCodes": {
              "$ref": "#/$defs/stringArray"
            },
            "maxAttempts": {
              "type": "integer",
              "minimum": 1
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "cancel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "draftMatches": {
              "type": "string"
            },
            "draftIncludes": {
              "$ref": "#/$defs/stringArray"
            },
            "reason": {
              "type": "string"
            }
          }
        }
      }
    },
    "pageExtractor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "matches": {
          "$ref": "#/$defs/stringArray"
        },
        "includeSelectors": {
          "$ref": "#/$defs/stringArray"
        },
        "excludeSelectors": {
          "$ref": "#/$defs/stringArray"
        },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "include": {
              "$ref": "#/$defs/stringArray"
            },
            "exclude": {
              "$ref": "#/$defs/stringArray"
            }
          }
        },
        "strategy": {
          "type": "string",
          "enum": ["replace", "prepend", "append"]
        },
        "priority": {
          "type": "number"
        },
        "maxTextLength": {
          "type": "integer",
          "minimum": 1
        },
        "collapseWhitespace": {
          "type": "boolean"
        }
      }
    },
    "selectionAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "anyOf": [
        {
          "required": ["prompt"]
        },
        {
          "required": ["text"]
        },
        {
          "required": ["promptTemplate"]
        }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "title": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "promptTemplate": {
          "type": "string"
        },
        "focus": {
          "type": "boolean"
        },
        "separator": {
          "type": "string"
        },
        "offsetX": {
          "type": "number"
        },
        "offsetY": {
          "type": "number"
        },
        "minLength": {
          "type": "integer",
          "minimum": 1
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "shellExecute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["import_text", "insert_text", "set_draft", "show_toast", "open_page"]
        },
        "text": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "focus": {
          "type": "boolean"
        },
        "separator": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "toastType": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "durationMs": {
          "type": "integer",
          "minimum": 1
        },
        "page": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "enum": ["import_text", "insert_text", "set_draft"]
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": ["text"]
              },
              {
                "required": ["prompt"]
              },
              {
                "required": ["template"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "show_toast"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "required": ["message"]
              },
              {
                "required": ["text"]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "open_page"
              }
            }
          },
          "then": {
            "required": ["page"]
          }
        }
      ]
    },
    "inputAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execute"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "variant": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "background": {
          "type": "string"
        },
        "color": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "execute": {
          "$ref": "#/$defs/shellExecute"
        }
      }
    },
    "menuItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "execute"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "icon": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "disclosure": {
          "type": "boolean"
        },
        "disabled": {
          "type": "boolean"
        },
        "execute": {
          "$ref": "#/$defs/shellExecute"
        }
      }
    },
    "slashCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "anyOf": [
        {
          "required": ["prompt"]
        },
        {
          "required": ["text"]
        },
        {
          "required": ["template"]
        }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "label": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "aliases": {
          "$ref": "#/$defs/stringArray"
        },
        "prompt": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "template": {
          "type": "string"
        },
        "separator": {
          "type": "string"
        },
        "disabled": {
          "type": "boolean"
        },
        "order": {
          "type": "number"
        }
      }
    },
    "legacyDeclarative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["prompt_fragment", "request_policy", "page_extractor"]
        },
        "placement": {
          "type": "string",
          "enum": ["system.prepend", "system.append"]
        },
        "content": {
          "type": "string"
        },
        "contentKey": {
          "type": "string"
        },
        "priority": {
          "type": "number"
        },
        "applyTo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "modes": {
              "$ref": "#/$defs/stringArray"
            },
            "modelIncludes": {
              "$ref": "#/$defs/stringArray"
            },
            "urlIncludes": {
              "$ref": "#/$defs/stringArray"
            }
          }
        },
        "promptFragments": {
          "$ref": "#/$defs/promptFragmentList"
        },
        "requestPatch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "body": {
              "type": "object"
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "onErrorCodes": {
              "$ref": "#/$defs/stringArray"
            },
            "maxAttempts": {
              "type": "integer",
              "minimum": 1
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "cancel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "draftMatches": {
              "type": "string"
            },
            "draftIncludes": {
              "$ref": "#/$defs/stringArray"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "matches": {
          "$ref": "#/$defs/stringArray"
        },
        "includeSelectors": {
          "$ref": "#/$defs/stringArray"
        },
        "excludeSelectors": {
          "$ref": "#/$defs/stringArray"
        },
        "strategy": {
          "type": "string",
          "enum": ["replace", "prepend", "append"]
        },
        "maxTextLength": {
          "type": "integer",
          "minimum": 1
        },
        "collapseWhitespace": {
          "type": "boolean"
        }
      }
    },
    "contributions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promptFragments": {
          "$ref": "#/$defs/promptFragmentList"
        },
        "requestPolicies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requestPolicy"
          }
        },
        "pageExtractors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pageExtractor"
          }
        },
        "selectionActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/selectionAction"
          }
        },
        "inputActions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputAction"
          }
        },
        "menuItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/menuItem"
          }
        },
        "slashCommands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slashCommand"
          }
        }
      }
    }
  }
}
