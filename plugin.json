{
  "schemaVersion": 2,
  "id": "template.page.selection-helper",
  "version": "0.1.0",
  "kind": "script",
  "scope": "page",
  "displayName": "Selection Helper Template",
  "description": "A starter page plugin that shows an anchored action for selected text and imports a prompt into Cerebr.",
  "defaultEnabled": true,
  "requiresExtension": true,
  "permissions": [
    "page:selection:read",
    "page:selection:clear",
    "shell:input:write",
    "ui:anchored-action"
  ],
  "activationEvents": ["page.ready"],
  "compatibility": {
    "versionRange": ">=2.4.86 <3.0.0"
  },
  "script": {
    "entry": "./page.js"
  }
}
